PORT=3001
JWT_SECRET=change-this-to-a-random-secret-in-production
DB_PATH=/data/trust-home.db

# WhatsApp (via whatsapp-server on port 3099)
WHATSAPP_SERVER_URL=http://localhost:3099

# SMS via Twilio (optional — fallback to WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS via MSG91 (optional — fallback to WhatsApp)
MSG91_AUTH_KEY=
MSG91_SENDER=TRUSTH

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@trusthomeservices.com
